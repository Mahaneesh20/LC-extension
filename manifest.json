{
  "manifest_version": 3,
  "name": "LeetCode Accepted -> Google Sheet",
  "version": "0.1.0",
  "description": "Automatically sends accepted LeetCode submissions to your Google Sheet endpoint.",
  "permissions": ["storage", "alarms"],
  "host_permissions": [
    "https://leetcode.com/*",
    "https://*.leetcode.com/*",
    "https://script.google.com/*",
    "https://script.googleusercontent.com/*"
  ],
  "background": {
    "service_worker": "src/background/service-worker.js"
  },
  "action": {
    "default_title": "LeetCode Sheet Sync",
    "default_popup": "src/popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://leetcode.com/problems/*"],
      "js": ["src/shared/constants.js", "src/content/content.js"],
      "run_at": "document_idle"
    }
  ]
}
